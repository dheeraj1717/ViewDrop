{
  "manifest_version": 3,
  "name": "VeloRecord Pro",
  "version": "1.0.0",
  "description": "A premium screen, webcam, and audio recorder with drawing tools and built-in editor.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "offscreen"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VeloRecord Pro"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css", "dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
